{
  "name": "power-atlas",
  "version": "0.1.0",
  "private": true,
  "description": "AI Infrastructure Site to Power Visualizer - public-data planning simulator",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "ingest:osm-power": "tsx scripts/ingest-osm-power.ts",
    "ingest:osm-water": "tsx scripts/ingest-osm-water.ts",
    "ingest:fema-flood": "tsx scripts/ingest-fema-flood.ts",
    "ingest:region": "npm run ingest:osm-power && npm run ingest:osm-water && npm run ingest:fema-flood"
  },
  "dependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/react": "^9.1.0",
    "@react-three/fiber": "^9.6.1",
    "axios": "^1.7.9",
    "maplibre-gl": "^5.1.0",
    "next": "^15.1.6",
    "osmtogeojson": "^3.0.0-beta.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.0.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.8",
    "postcss": "^8.5.10"
