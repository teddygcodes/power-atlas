# Power Atlas v0.1 environment

# Overpass API endpoint (used ONLY by scripts/ingest-osm-power.ts, never the browser).
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Default region + bounding box for ingestion (south,west,north,east).
# Atlanta / North Georgia corridor.
DEFAULT_REGION=georgia-demo
DEFAULT_BBOX=33.4,-84.8,34.3,-83.8
